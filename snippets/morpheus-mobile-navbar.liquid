{% doc %}
  Renders the fixed Morpheus mobile navbar.
{% enddoc %}

{% liquid
  assign home_url = routes.root_url
  assign shop_url = routes.all_products_collection_url
  assign sale_url = routes.all_products_collection_url
  assign profile_url = routes.account_login_url
  assign is_sale_active = false
  if customer
    assign profile_url = routes.account_url
  endif

  for link in linklists['main-menu'].links
    assign normalized_title = link.title | downcase
    if normalized_title == 'home'
      assign home_url = link.url
    elsif normalized_title == 'shop'
      assign shop_url = link.url
    elsif normalized_title == 'on sale'
      assign sale_url = link.url
    endif
  endfor

  if request.query_string contains 'sale=true'
    assign is_sale_active = true
  endif
%}

<nav class="mobile-nav" aria-label="Mobile navigation">
  <div class="nav">
    <a href="{{ home_url }}" class="nav-item{% if request.path == home_url %} active{% endif %}">
      <i class="bi bi-house-door"></i>
      <span class="nav-text">Home</span>
    </a>
    <a href="{{ shop_url }}" class="nav-item{% if request.path contains shop_url and shop_url != routes.root_url %} active{% endif %}">
      <i class="bi bi-grid"></i>
      <span class="nav-text">Shop</span>
    </a>
    <a href="{{ sale_url }}" class="nav-item{% if is_sale_active %} active{% endif %}">
      <i class="bi bi-tag-fill sale-icon"></i>
      <span class="nav-text">On Sale</span>
    </a>
    <a href="{{ profile_url }}" class="nav-item{% if request.path contains '/account' %} active{% endif %}">
      <i class="bi bi-person"></i>
      <span class="nav-text">Profile</span>
    </a>
  </div>
</nav>
