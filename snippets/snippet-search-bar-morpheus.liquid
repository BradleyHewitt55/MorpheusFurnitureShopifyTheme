{% doc %}
  Renders the Morpheus shell search bar with a menu-driven filter dropdown.
{% enddoc %}

{% liquid
  assign search_menu = linklists['searchbar-menus']
%}

<form action="{{ routes.search_url }}" method="get" role="search" class="search-bar-wrapper" data-search-form>
  <div class="filter-toggle" data-search-filter-toggle tabindex="0" role="button" aria-expanded="false" aria-label="Search filter">
    <span data-search-filter-label>All Categories</span>
    {% render 'morpheus-icon', name: 'chevron-down' %}

    <div class="filter-dropdown" data-search-filter-dropdown>
      <button
        type="button"
        class="dropdown-item active"
        data-search-option
        data-label="All Categories"
        data-search-types=""
      >
        All Categories
      </button>

      {% for link in search_menu.links %}
        {% liquid
          assign normalized_title = link.title | downcase
          assign search_types = ''
          if normalized_title contains 'blog'
            assign search_types = 'article'
          elsif normalized_title contains 'page'
            assign search_types = 'page'
          elsif normalized_title contains 'collection'
            assign search_types = 'product,collection'
          elsif normalized_title contains 'product'
            assign search_types = 'product'
          endif
        %}
        <button
          type="button"
          class="dropdown-item"
          data-search-option
          data-label="{{ link.title | escape }}"
          data-search-types="{{ search_types }}"
          data-search-url="{{ link.url }}"
        >
          {{ link.title }}
        </button>
      {% endfor %}
    </div>
  </div>

  <input type="hidden" name="options[prefix]" value="last">
  <input type="hidden" name="options[unavailable_products]" value="last">
  <input type="hidden" name="type" value="" data-search-type-input>

  <input
    type="search"
    name="q"
    class="search-input"
    value="{{ search.terms | escape }}"
    placeholder="Search products, pages, and more"
    autocomplete="off"
    autocorrect="off"
    autocapitalize="off"
    spellcheck="false"
  >

  <button type="submit" class="search-btn" aria-label="Search">
    {% render 'morpheus-icon', name: 'search' %}
  </button>
</form>

<div class="dropdown-overlay" data-search-overlay hidden></div>
