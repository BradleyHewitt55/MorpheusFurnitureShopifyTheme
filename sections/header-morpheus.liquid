{% liquid
  assign main_menu = linklists['main-menu']
  assign account_target = routes.account_login_url
  if customer
    assign account_target = routes.account_url
  endif
%}

<style>
  {% if section.settings.sticky_header %}
    .section-header-morpheus {
      position: sticky;
      top: 0;
      z-index: 320;
    }
  {% endif %}
</style>

{{ 'section-header-morpheus.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-header-morpheus.js' | asset_url }}" defer></script>

<header
  class="section-header-morpheus"
  data-section-id="{{ section.id }}"
  data-enable-cart-drawer="{{ section.settings.enable_cart_drawer }}"
>
  <div class="top-navbar search-open" data-morpheus-header>
    <div class="main-column">
      {% if request.page_type != 'index' %}
        <button class="icon-btn back-btn" type="button" aria-label="Go back" data-back-button>
          {% render 'morpheus-icon', name: 'back' %}
        </button>
      {% endif %}

      <a href="{{ routes.root_url }}" class="logo" aria-label="{{ shop.name }}">
        {% if settings.logo %}
          {{
            settings.logo
            | image_url: width: 500
            | image_tag: alt: shop.name, loading: 'eager'
          }}
        {% else %}
          <span>{{ shop.name }}</span>
        {% endif %}
      </a>

      <nav class="desktop-nav" aria-label="Primary navigation">
        {% for link in main_menu.links %}
          <a
            href="{{ link.url }}"
            class="nav-link{% if link.current %} active{% endif %}"
            {% if link.current %}aria-current="page"{% endif %}
          >
            {% if link.title == 'On Sale' %}
              {% render 'morpheus-icon', name: 'tag' %}
            {% endif %}
            <span>{{ link.title }}</span>
          </a>
        {% endfor %}
      </nav>

      <div class="actions">
        <button class="icon-btn search-toggle" type="button" aria-label="Search" aria-expanded="true" data-search-toggle>
          {% render 'morpheus-icon', name: 'search' %}
        </button>

        <button class="icon-btn cart-btn" type="button" aria-label="Cart" data-cart-trigger>
          {% render 'morpheus-icon', name: 'cart' %}
          <span class="badge{% if cart.item_count == 0 %} hidden{% endif %}" data-cart-count>
            {% if cart.item_count > 99 %}99+{% else %}{{ cart.item_count }}{% endif %}
          </span>
        </button>

        <div class="account-menu" data-account-menu>
          <a href="{{ account_target }}" class="icon-btn account-btn" aria-label="Account" data-account-button aria-expanded="false">
            {% render 'morpheus-icon', name: 'person' %}
            {% if customer %}
              <span class="status-dot"></span>
            {% endif %}
          </a>

          <div class="account-dropdown" hidden data-account-dropdown>
            {% if customer %}
              <a href="{{ routes.account_url }}" class="account-link">
                {% render 'morpheus-icon', name: 'person' %}
                <span>Profile</span>
              </a>
              <a href="{{ routes.account_addresses_url }}" class="account-link">
                {% render 'morpheus-icon', name: 'wishlist' %}
                <span>Wishlist</span>
              </a>
              <a href="{{ routes.account_logout_url }}" class="account-link">
                {% render 'morpheus-icon', name: 'logout' %}
                <span>Logout</span>
              </a>
            {% else %}
              <a href="{{ routes.account_login_url }}" class="account-link">
                {% render 'morpheus-icon', name: 'login' %}
                <span>Login</span>
              </a>
              <a href="{{ routes.account_register_url }}" class="account-link">
                {% render 'morpheus-icon', name: 'register' %}
                <span>Register</span>
              </a>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="burger-menu">
        {% render 'morpheus-burger' %}
      </div>
    </div>

    <div class="search-column">
      {% render 'snippet-search-bar-morpheus' %}
    </div>
  </div>

  <div class="sidebar-layer" data-sidebar-overlay></div>
  {% render 'morpheus-sidebar-menu' %}
  {% render 'morpheus-mobile-navbar' %}
  {% render 'morpheus-floating-cart' %}
</header>

{% schema %}
{
  "name": "Header - Morpheus",
  "settings": [
    {
      "type": "header",
      "content": "Header settings"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Sticky header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_cart_drawer",
      "label": "Enable cart drawer",
      "default": true
    }
  ]
}
{% endschema %}
