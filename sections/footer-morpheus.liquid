{% liquid
  assign product_links = linklists['footer']
  assign help_links = linklists['help-advice']
%}

{{ 'section-footer-morpheus.css' | asset_url | stylesheet_tag }}

<footer class="footer section-footer-morpheus" data-section-id="{{ section.id }}">
  <section class="brand-info">
    <div class="logo">
      {% if settings.logo %}
        {{
          settings.logo
          | image_url: width: 500
          | image_tag: alt: shop.name, loading: 'lazy'
        }}
      {% else %}
        <span>{{ shop.name }}</span>
      {% endif %}
    </div>

    <ul class="contact-details">
      <li>Email: <a href="mailto:support@morpheusfurniture.co.za">support@morpheusfurniture.co.za</a></li>
      <li><a href="tel:+27618523328">Phone: +27 61 852 3328</a></li>
      <li><a href="https://wa.me/27618523328" target="_blank" rel="noopener noreferrer">WhatsApp: +27 61 852 3328</a></li>
    </ul>
  </section>

  <section class="products">
    <h3>Products</h3>
    <ul class="link-list">
      {% for link in product_links.links %}
        <li>
          <a href="{{ link.url }}">{{ link.title }}</a>
        </li>
      {% endfor %}
    </ul>
  </section>

  <section class="help-advice">
    <h3>Help &amp; Advice</h3>
    <ul class="link-list">
      {% for link in help_links.links %}
        <li>
          <a href="{{ link.url }}">{{ link.title }}</a>
        </li>
      {% endfor %}
    </ul>
  </section>

  <section class="social-media">
    <h3>Follow Us On</h3>
    <div class="social-icons">
      {% if settings.social_instagram_link != blank %}
        <a href="{{ settings.social_instagram_link }}" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
          <i class="bi bi-instagram"></i>
        </a>
      {% endif %}
      {% if settings.social_facebook_link != blank %}
        <a href="{{ settings.social_facebook_link }}" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
          <i class="bi bi-facebook"></i>
        </a>
      {% endif %}
      <a href="https://wa.me/27618523328" aria-label="WhatsApp" target="_blank" rel="noopener noreferrer">
        <i class="bi bi-whatsapp"></i>
      </a>
    </div>
  </section>

  <section class="newsletter">
    <h3>Subscribe</h3>
    <p>Get updates on new products and special offers</p>
    {%- form 'customer', id: '975833', class: 'newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="newsletter-field-wrapper">
        <input
          id="FooterNewsletterEmail-{{ section.id }}"
          type="email"
          name="contact[email]"
          class="newsletter-input"
          value="{{ form.email }}"
          placeholder="Enter your email"
          autocomplete="email"
          required
        >
        <button type="submit" class="newsletter-btn" aria-label="Subscribe">
          <i class="bi bi-send"></i>
        </button>
      </div>

      {% if form.errors %}
        <p class="newsletter-error">{{ form.errors | default_errors }}</p>
      {% endif %}

      {% if form.posted_successfully? %}
        <p class="newsletter-success">Thanks for subscribing!</p>
      {% endif %}
    {%- endform -%}
  </section>
</footer>

{% schema %}
{
  "name": "Footer - Morpheus",
  "settings": []
}
{% endschema %}
